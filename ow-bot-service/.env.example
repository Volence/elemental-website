# Web app connection
OW_BOT_WEB_APP_URL=https://elmt.gg
OW_BOT_WEB_APP_SECRET=your-shared-secret-here

# OW paths (Windows defaults, adjust if needed)
OW_BOT_OW_INSTALL_DIR=C:\Program Files (x86)\Overwatch
OW_BOT_WORKSHOP_LOG_DIR=C:\Users\YourUser\Documents\Overwatch\Workshop
OW_BOT_BATTLENET_EXE=C:\Program Files (x86)\Battle.net\Battle.net.exe

# Instance limits
OW_BOT_MAX_INSTANCES=5
OW_BOT_WARMUP_TIMEOUT_SECONDS=180
OW_BOT_INVITE_TIMEOUT_SECONDS=300
OW_BOT_IDLE_SHUTDOWN_SECONDS=7200
OW_BOT_HEALTH_CHECK_INTERVAL_SECONDS=30

# Server
OW_BOT_HOST=0.0.0.0
OW_BOT_PORT=8420

# Battle.net accounts (JSON array)
# Each account: {"email": "", "password": "", "authenticator_secret": "", "screen_region": [0, 0, 1280, 720]}
# OW_BOT_ACCOUNTS='[{"email":"acct1@example.com","password":"...","authenticator_secret":"BASE32SECRET","screen_region":[0,0,1280,720]}]'
